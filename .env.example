# MongoDB Atlas connection string.
# Create a free cluster at https://cloud.mongodb.com and paste the SRV URI here.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/encore?retryWrites=true&w=majority"

# Random 32+ char secret used to sign host session cookies (JWT HS256).
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
